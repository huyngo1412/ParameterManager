<Window x:Class="ParameterManager.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ParameterManager.Models"
        Title="Parameter Manager"
        Height="720"
        Width="1320"
        MinHeight="600"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F8FC">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ParameterManager;component/Resources/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="303*"/>
            <ColumnDefinition Width="364*"/>
            <ColumnDefinition Width="625*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
        Style="{StaticResource LookupPanelBorderStyle}">

                <DockPanel LastChildFill="True">

                    <!-- TITLE -->
                    <TextBlock DockPanel.Dock="Top"
                   Text="Parameter Manager"
                   Style="{StaticResource TitleTextStyle}"/>

                    <!-- CATEGORY MULTI SELECT: đứng trước TreeView -->
                    <Grid DockPanel.Dock="Top"
              Margin="16,0,20,8">

                        <ToggleButton x:Name="CategoryDropDownButton"
                          Content="{Binding SelectedCategorySummary}"
                          IsChecked="{Binding IsCategoryPopupOpen, Mode=TwoWay}"
                          Style="{StaticResource MultiSelectCategoryButtonStyle}"/>

                        <Popup IsOpen="{Binding IsCategoryPopupOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=CategoryDropDownButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">

                            <Border Width="{Binding ActualWidth, ElementName=CategoryDropDownButton}"
                        MaxHeight="320"
                        Background="White"
                        BorderBrush="#90CAF9"
                        BorderThickness="1">

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Categories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="8,4"
                                              FontSize="12"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- SCOPE: RadioButton thay cho Button -->
                    <StackPanel DockPanel.Dock="Top"
                    Margin="16,0,20,8">

                        <TextBlock Text="{Binding SelectionScopeText}"
                       Foreground="#5F6B7A"
                       FontSize="12"
                       Margin="0,0,0,4"/>

                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Active View"
                             GroupName="ScopeMode"
                             IsChecked="{Binding IsActiveViewScope, Mode=TwoWay}"
                             Style="{StaticResource ScopeRadioButtonStyle}"/>

                            <RadioButton Content="All Project"
                             GroupName="ScopeMode"
                             IsChecked="{Binding IsAllProjectScope, Mode=TwoWay}"
                             Style="{StaticResource ScopeRadioButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ACTION BUTTONS: đưa xuống đáy panel trái -->
                    <Border DockPanel.Dock="Bottom"
                Style="{StaticResource LeftActionPanelBorderStyle}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                           Text="Element Actions"
                           Foreground="#374151"
                           FontSize="12"
                           FontWeight="SemiBold"/>

                            <UniformGrid Grid.Row="2"
                             Columns="2">

                                <ToggleButton Content="Select"
                                  Command="{Binding SelectElementsCommand}"
                                  IsChecked="{Binding IsSelectActionActive, Mode=OneWay}"
                                  Style="{StaticResource LeftActionToggleButtonStyle}"/>

                                <ToggleButton Content="Deselect"
                                  Command="{Binding DeselectElementsCommand}"
                                  IsChecked="{Binding IsDeselectActionActive, Mode=OneWay}"
                                  Style="{StaticResource LeftActionToggleButtonStyle}"/>

                                <ToggleButton Content="Hide"
                                  Command="{Binding HideElementsCommand}"
                                  IsChecked="{Binding IsHideActionActive, Mode=OneWay}"
                                  Style="{StaticResource LeftActionToggleButtonStyle}"/>

                                <ToggleButton Content="Unhide"
                                  Command="{Binding UnhideElementsCommand}"
                                  IsChecked="{Binding IsUnhideActionActive, Mode=OneWay}"
                                  Style="{StaticResource LeftActionToggleButtonStyle}"/>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <!-- TREEVIEW: nằm giữa, sau category/scope và trước action buttons -->
                    <TreeView ItemsSource="{Binding FamilyTree}"
                  Style="{StaticResource LeftTreeMenuStyle}"
                  ItemContainerStyle="{StaticResource LeftTreeMenuItemStyle}">

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid MinHeight="26"
                          Margin="0,1,0,1">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                  Margin="4,0,8,0"
                                  VerticalAlignment="Center"
                                  IsThreeState="True"
                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource LeftTreeNodeTextStyle}"/>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="2"
                    Style="{StaticResource LookupPanelBorderStyle}">

                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TYPE PARAMETERS COLUMN -->
                    <Border Grid.Column="0"
                            BorderBrush="#D7E5F7"
                            BorderThickness="0,0,1,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- TITLE -->
                            <Border Grid.Row="0"
                                    Background="#EAF3FC"
                                    BorderBrush="#9FB8D2"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,9">

                                <TextBlock Text="Type Parameters"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#0F172A"/>
                            </Border>

                            <!-- HEADER -->
                            <Border Grid.Row="1"
                                    Background="#F3F7FC"
                                    BorderBrush="#D7E5F7"
                                    BorderThickness="0,0,0,1">

                                <Grid Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Parameter"
                                               Style="{StaticResource HeaderTextStyle}"/>

                                    <Border Grid.Column="1"
                                            BorderBrush="#D7E5F7"
                                            BorderThickness="1,0,0,0">

                                        <TextBlock Text="Value"
                                                   Style="{StaticResource HeaderTextStyle}"/>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="#F3F7FC"
                                            BorderBrush="#D7E5F7"
                                            BorderThickness="1,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- TREE -->
                            <TreeView Grid.Row="2"
                                      ItemsSource="{Binding TypeParameterTree}"
                                      Style="{StaticResource RightLookupTreeStyle}"
                                      ItemContainerStyle="{StaticResource RightLookupTreeItemStyle}"
                                      PreviewMouseLeftButtonDown="ParameterTreeView_PreviewMouseLeftButtonDown"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type models:ParameterTreeNode}"
                                                              ItemsSource="{Binding Children}">

                                        <Grid MinHeight="24"
                                              HorizontalAlignment="Stretch"
                                              SnapsToDevicePixels="True">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.ColumnSpan="2"
                                                    Style="{StaticResource RightLookupRowBackgroundStyle}"/>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Member}"
                                                       ToolTip="{Binding ToolTipText}"
                                                       Style="{StaticResource RightLookupMemberTextStyle}"/>

                                            <Border Grid.Column="1"
                                                    BorderBrush="#D0D7E2"
                                                    BorderThickness="1,0,0,0">

                                                <ContentControl Content="{Binding}"
                                                                Style="{StaticResource ParameterValueEditorHostStyle}"/>
                                            </Border>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </Border>

                    <!-- INSTANCE PARAMETERS COLUMN -->
                    <Border Grid.Column="2">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- TITLE -->
                            <Border Grid.Row="0"
                                    Background="#EAF3FC"
                                    BorderBrush="#9FB8D2"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,9">

                                <TextBlock Text="Instance Parameters"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#0F172A"/>
                            </Border>

                            <!-- HEADER -->
                            <Border Grid.Row="1"
                                    Background="#F3F7FC"
                                    BorderBrush="#D7E5F7"
                                    BorderThickness="0,0,0,1">

                                <Grid Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Parameter"
                                               Style="{StaticResource HeaderTextStyle}"/>

                                    <Border Grid.Column="1"
                                            BorderBrush="#D7E5F7"
                                            BorderThickness="1,0,0,0">

                                        <TextBlock Text="Value"
                                                   Style="{StaticResource HeaderTextStyle}"/>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="#F3F7FC"
                                            BorderBrush="#D7E5F7"
                                            BorderThickness="1,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- TREE -->
                            <TreeView Grid.Row="2"
                                      ItemsSource="{Binding InstanceParameterTree}"
                                      Style="{StaticResource RightLookupTreeStyle}"
                                      ItemContainerStyle="{StaticResource RightLookupTreeItemStyle}"
                                      PreviewMouseLeftButtonDown="ParameterTreeView_PreviewMouseLeftButtonDown"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type models:ParameterTreeNode}"
                                                              ItemsSource="{Binding Children}">

                                        <Grid MinHeight="24"
                                              HorizontalAlignment="Stretch"
                                              SnapsToDevicePixels="True">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.ColumnSpan="2"
                                                    Style="{StaticResource RightLookupRowBackgroundStyle}"/>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Member}"
                                                       ToolTip="{Binding ToolTipText}"
                                                       Style="{StaticResource RightLookupMemberTextStyle}"/>

                                            <Border Grid.Column="1"
                                                    BorderBrush="#D0D7E2"
                                                    BorderThickness="1,0,0,0">

                                                <ContentControl Content="{Binding}"
                                                                Style="{StaticResource ParameterValueEditorHostStyle}"/>
                                            </Border>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Foreground="#5F6B7A"
                       FontSize="12"/>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Button Grid.Column="3"
                    Content="Assign Parameter"
                    Command="{Binding AssignCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </Grid>
    </Grid>
</Window>