<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="LookupPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#D9E3F0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#1F2937"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="RightLookupTreeStyle" TargetType="TreeView">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Không còn mũi tên tam giác expand/collapse -->
    <Style x:Key="RightLookupTreeItemStyle" TargetType="TreeViewItem">
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ContentPresenter Grid.Row="0"
                                          ContentSource="Header"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="True"/>

                        <ItemsPresenter x:Name="ItemsHost"
                                        Grid.Row="1"
                                        Margin="0"
                                        SnapsToDevicePixels="True"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RightLookupValueTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="22"/>
        <Setter Property="Margin" Value="2,1,4,1"/>
        <Setter Property="Padding" Value="4,1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="#1F2937"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                <Setter Property="Visibility" Value="Hidden"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsEdited}" Value="True">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#B26A00"/>
            </DataTrigger>

            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#1976D2"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MaterialComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="22"/>
        <Setter Property="Margin" Value="2,1,4,1"/>
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#BFD4EA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#1F2937"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <DataTemplate x:Key="TextValueEditorTemplate">
        <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="{Binding IsReadOnly}"
                 ToolTip="{Binding ToolTipText}"
                 Style="{StaticResource RightLookupValueTextBoxStyle}"/>
    </DataTemplate>

    <DataTemplate x:Key="MaterialValueEditorTemplate">
        <ComboBox ItemsSource="{Binding MaterialOptions}"
                  SelectedItem="{Binding SelectedMaterial, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  DisplayMemberPath="Name"
                  IsEnabled="{Binding CanEdit}"
                  Style="{StaticResource MaterialComboBoxStyle}"/>
    </DataTemplate>

    <DataTemplate x:Key="BooleanValueEditorTemplate">
        <CheckBox IsChecked="{Binding BooleanValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              IsThreeState="True"
              VerticalAlignment="Center"
              HorizontalAlignment="Left"
              Margin="6,0,0,0"/>
    </DataTemplate>

    <DataTemplate x:Key="ElementComboValueEditorTemplate">
        <ComboBox ItemsSource="{Binding ElementOptions}"
              SelectedItem="{Binding SelectedElementOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              DisplayMemberPath="Name"
              IsEnabled="{Binding CanEdit}"
              Style="{StaticResource MaterialComboBoxStyle}"/>
    </DataTemplate>

    <DataTemplate x:Key="ImagePickerValueEditorTemplate">
        <Grid Margin="2,1,4,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                 Text="{Binding Value}"
                 IsReadOnly="True"
                 Style="{StaticResource RightLookupValueTextBoxStyle}"/>

            <Button Grid.Column="1"
                Content="..."
                Command="{Binding DataContext.OpenImagePickerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}"
                Height="22"
                Padding="0"/>
        </Grid>
    </DataTemplate>

    <Style x:Key="ParameterValueEditorHostStyle" TargetType="ContentControl">
        <Setter Property="ContentTemplate" Value="{StaticResource TextValueEditorTemplate}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsBooleanEditor}" Value="True">
                <Setter Property="ContentTemplate" Value="{StaticResource BooleanValueEditorTemplate}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsElementComboEditor}" Value="True">
                <Setter Property="ContentTemplate" Value="{StaticResource ElementComboValueEditorTemplate}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsImagePickerEditor}" Value="True">
                <Setter Property="ContentTemplate" Value="{StaticResource ImagePickerValueEditorTemplate}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                <Setter Property="Visibility" Value="Hidden"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RightLookupRowBackgroundStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="#D7DDE7"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                <Setter Property="Background" Value="#8FAECC"/>
                <Setter Property="BorderBrush" Value="#6F91B3"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsEdited}" Value="True">
                <Setter Property="Background" Value="#FFF8D9"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RightLookupMemberTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="FontSize" Value="12.2"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="Black"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding CanEdit}" Value="True">
                <Setter Property="Foreground" Value="#0057B8"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>