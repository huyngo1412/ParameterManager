<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="16,14,16,10"/>
        <Setter Property="FontSize" Value="21"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#1F2937"/>
    </Style>

    <Style x:Key="MultiSelectCategoryButtonStyle" TargetType="ToggleButton">
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="9,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#1F2937"/>
        <Setter Property="BorderBrush" Value="#BFD4EA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="LeftTreeMenuStyle" TargetType="TreeView">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="12,0,12,12"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="LeftTreeMenuItemStyle" TargetType="TreeViewItem">
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="LeftTreeNodeTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCategoryNode}" Value="True">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#1F2937"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsFamilyNode}" Value="True">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#1F2937"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="ScopeRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Height" Value="24"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="LeftActionToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#1976D2"/>
        <Setter Property="BorderBrush" Value="#90CAF9"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EAF3FC"/>
                <Setter Property="BorderBrush" Value="#1976D2"/>
            </Trigger>

            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="#1976D2"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#1976D2"/>
            </Trigger>

            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#0D47A1"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LeftActionPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#F8FBFF"/>
        <Setter Property="BorderBrush" Value="#D7E5F7"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="12,8,12,12"/>
    </Style>
</ResourceDictionary>
